# Go build output
/bin/

# Web frontend
node_modules/
web/dist/
web/dist-static/
web/dist-server/
web/*.tsbuildinfo

# Local static-site preview (make site)
/_site/

# make site-dev artifact (export-site's throwaway stub frontend; the data is served from _site by a dev middleware)
/.site-stub/

# Lighthouse reports (make lighthouse / lhci)
/.lighthouseci/

# Embedded web UI build output (only the placeholder index.html is tracked;
# the real assets are produced by the web build and copied in before embedding).
/internal/track/webui/dist/*
!/internal/track/webui/dist/index.html

# Nix
/result
.direnv/
.pre-commit-config.yaml

# Editor
*.swp
*.swo

# Claude Code
.claude/

# Local scratch notes
.local/
devlog/
